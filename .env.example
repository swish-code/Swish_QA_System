# =====================================================================
# Swish QA System — environment configuration
# Copy this file to `.env.local` (dev) or set these vars in your host
# (Railway / Docker / etc.) for production.
# =====================================================================

# --- REQUIRED ---------------------------------------------------------

# PostgreSQL connection string.
# On Railway: add a reference to the Postgres service's ${{Postgres.DATABASE_URL}}
# (Service settings → Variables → New Variable → DATABASE_URL → Reference)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Secret used to sign JWT auth tokens. Use a long random string (>= 32 chars).
# Generate one with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# If unset in production, the server falls back to a dev secret and logs a warning.
JWT_SECRET=

# --- OPTIONAL ---------------------------------------------------------

# Google Gemini API key — enables the in-app AI Assistant feature.
# Get one at: https://aistudio.google.com/apikey
# Leave blank to disable AI features (everything else works without it).
GEMINI_API_KEY=

# Bootstrap password used ONLY when the database is empty and the initial
# supervisor user ('admin') is auto-created on first boot. After first login
# the supervisor should change their password from the UI; this var is then
# ignored. Defaults to 'admin123' if unset.
ADMIN_PASSWORD=

# Node environment. Set to 'production' on hosted deployments to skip the
# Vite dev middleware and serve the prebuilt SPA from dist/.
# NODE_ENV=production

# Disable Vite Hot Module Replacement in environments where the websocket
# can't connect (e.g. AI Studio). Set to 'true' to disable.
# DISABLE_HMR=true
